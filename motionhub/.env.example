# ---- Database ----
# Dev default is SQLite (file). For production swap to Postgres/Supabase and change
# provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# ---- Stripe ----
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# From `stripe listen --forward-to localhost:3000/api/webhook`
STRIPE_WEBHOOK_SECRET="whsec_xxx"
# Enable Alipay & WeChat Pay in Stripe Dashboard > Settings > Payment methods.
# Comma-separated. Card is always on. e.g. "card,alipay,wechat_pay"
STRIPE_PAYMENT_METHODS="card,alipay,wechat_pay"

# ---- App ----
# Public base URL, used for Stripe redirects.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Price (in cents) to unlock a single premium prompt.
UNLOCK_PRICE_CENTS="500"
UNLOCK_CURRENCY="usd"
